{
    "id": "ais",
    "name": "AIS",
    "version": "1.0.0",
    "description": "Automatic Identification System — maritime vessel tracking via NMEA 0183 (AIVDM/AIVDO)",
    "author": "Weibel Ventures",
    "icon": "ship",
    "color": "#34C759",
    "api_version": 1,

    "ingestor": {
        "type": "tcp_connect",
        "default_port": 5631
    },

    "list_columns": [
        {"key": "mmsi", "label": "MMSI", "width": 80, "sortable": true},
        {"key": "vessel_name", "label": "Vessel", "width": 100, "sortable": true},
        {"key": "msg_type", "label": "Type", "width": 40, "sortable": true},
        {"key": "summary", "label": "Summary", "width": null, "sortable": true}
    ],

    "settings_schema": {
        "type": "object",
        "properties": {
            "mode": {
                "type": "string",
                "title": "Mode",
                "default": "tcp_listen",
                "enum": ["tcp_listen", "tcp_connect", "udp"],
                "description": "tcp_listen: accept connections (default). tcp_connect: connect to remote feed. udp: listen for datagrams."
            },
            "tcp_port": {
                "type": "integer",
                "title": "TCP Port",
                "default": 5631,
                "minimum": 1,
                "maximum": 65535,
                "description": "Standard AIS NMEA port"
            },
            "udp_port": {
                "type": "integer",
                "title": "UDP Port",
                "default": 5631,
                "minimum": 1,
                "maximum": 65535
            },
            "host": {
                "type": "string",
                "title": "Remote Host",
                "default": "127.0.0.1",
                "description": "Only used in tcp_connect mode"
            },
            "reconnect_delay": {
                "type": "number",
                "title": "Reconnect delay (s)",
                "default": 5.0,
                "minimum": 1,
                "maximum": 60,
                "description": "Only used in tcp_connect mode"
            }
        }
    },

    "entity_types": ["track"],
    "map_layer": true,
    "supports_hex_dump": false
}
